{
  "name": "mineforge",
  "version": "1.0.1",
  "description": "Local AI chatbot and coding agent for Minecraft development.",
  "type": "module",
  "bin": {
    "mineforge": "bin/mineforge.js"
  },
  "files": [
    "bin/",
    "lib-node/",
    "src-node/",
    "scripts/npm-postinstall.js",
    "scripts/install.ps1",
    "scripts/install.sh",
    "minecraft_versions/",
    "python-backend/mineforgeai/**/*.py",
    "python-backend/mineforgeai/**/.gitkeep",
    "python-backend/pyproject.toml",
    "python-backend/requirements*.txt",
    "README.md",
    "LICENSE",
    "start_bot.py",
    "train.py",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test",
    "dev": "tsx src-node/cli.ts",
    "postinstall": "node ./scripts/npm-postinstall.js"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ttvbenjiarml/MineVerse.git"
  },
  "bugs": {
    "url": "https://github.com/ttvbenjiarml/MineVerse/issues"
  },
  "homepage": "https://github.com/ttvbenjiarml/MineVerse#readme",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
